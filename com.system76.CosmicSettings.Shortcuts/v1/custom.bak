{
    (
        modifiers: [
            Ctrl,
        ],
        key: "F4",
    ): Disable,
    (
        modifiers: [
            Alt,
        ],
        key: "space",
    ): Spawn("vicinae  toggle"),
    (
        modifiers: [
            Super,
        ],
        key: "p",
        description: Some("text ocr"),
    ): Spawn("~/nixos-dotfiles/modules/scripts/text-ocr/ocr.sh"),
    (
        modifiers: [
            Super,
            Shift,
        ],
        key: "F9",
        description: Some("Conservation Mode Off"),
    ): Spawn("~/nixos-dotfiles/modules/scripts/conservation_mode/off.sh"),
    (
        modifiers: [
            Ctrl,
        ],
        key: "BackSpace",
    ): Disable,
    (
        modifiers: [
            Ctrl,
        ],
        key: "c",
    ): Disable,
    (
        modifiers: [
            Super,
        ],
        key: "XF86AudioMute",
    ): System(MuteMic),
    (
        modifiers: [
            Super,
        ],
        key: "f",
    ): Maximize,
    (
        modifiers: [
            Super,
        ],
        key: "e",
    ): System(HomeFolder),
    (
        modifiers: [
            Super,
        ],
        key: "m",
    ): Disable,
    (
        modifiers: [
            Super,
        ],
        key: "F9",
        description: Some("Conservation Mode On"),
    ): Spawn("~/nixos-dotfiles/modules/scripts/conservation_mode/on.sh"),
}